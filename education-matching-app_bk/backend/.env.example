# OAuth Configuration
# Get credentials from respective provider developer portals

# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth - https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Twitter OAuth - https://developer.twitter.com/
TWITTER_CONSUMER_KEY=your_twitter_consumer_key_here
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret_here

# OAuth Callback Base URL (your backend URL)
OAUTH_CALLBACK_URL=https://education-matching-api-idea-dev.replit.app

# Database
DATABASE_URL=your_database_url_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Other existing environment variables...
